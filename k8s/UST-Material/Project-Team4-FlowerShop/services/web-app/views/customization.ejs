<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Customize | AFF</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <nav class="navbar">
    <div class="container">
      <a href="/dashboard" class="navbar-brand">AFF</a>
      <ul class="navbar-nav">
        <li><a href="/product">Shop</a></li>
        <li><a href="/customization">Customize</a></li>
        <li><a href="/cart">Cart</a></li>
        <li><a href="/seller">Sell</a></li>
        <li><a href="/knowmore">About</a></li>
        <li><a href="/auth/logout">Logout</a></li>
      </ul>
    </div>
  </nav>

  <section class="page-section">
    <div class="container" style="max-width: 600px;">
      <h2 class="section-title">Custom Order</h2>
      
      <% if (success_msg && success_msg.length > 0) { %>
        <div class="alert alert-success"><%= success_msg %></div>
      <% } %>
      <% if (error_msg && error_msg.length > 0) { %>
        <div class="alert alert-error"><%= error_msg %></div>
      <% } %>
      
      <div class="card">
        <form action="/customization/place-order" method="POST">
          <div class="form-group">
            <label class="form-label" for="flowerTypes">Flower Types</label>
            <input type="text" id="flowerTypes" name="flowerTypes" class="form-control" placeholder="e.g. Roses, Lilies, Tulips" required>
          </div>
          <div class="form-group">
            <label class="form-label" for="message">Card Message</label>
            <textarea id="message" name="message" class="form-control" placeholder="Your personalized message"></textarea>
          </div>
          <div class="form-group">
            <label class="form-label" for="wrapColor">Wrap Color</label>
            <select id="wrapColor" name="wrapColor" class="form-control">
              <option value="white">White</option>
              <option value="black">Black</option>
              <option value="kraft">Kraft Brown</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label" for="totalPrice">Budget ($)</label>
            <input type="number" id="totalPrice" name="totalPrice" class="form-control" placeholder="50" min="1" required>
          </div>
          <button type="submit" class="btn btn-primary" style="width:100%">Place Custom Order</button>
        </form>
      </div>
    </div>
  </section>

  <footer class="footer">
    <div class="container">
      <p>AFF — Customization via cart-api:3003</p>
    </div>
  </footer>
</body>
</html>
