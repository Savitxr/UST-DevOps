<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard | AFF</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <nav class="navbar">
    <div class="container">
      <a href="/dashboard" class="navbar-brand">AFF</a>
      <ul class="navbar-nav">
        <li><a href="/product">Shop</a></li>
        <li><a href="/customization">Customize</a></li>
        <li><a href="/cart">Cart</a></li>
        <li><a href="/seller">Sell</a></li>
        <li><a href="/knowmore">About</a></li>
        <li><a href="/auth/logout">Logout</a></li>
      </ul>
    </div>
  </nav>

  <section class="dashboard">
    <div class="container">
      <h2 class="section-title">Dashboard</h2>
      
      <div class="dashboard-grid">
        <a href="/product" class="dashboard-card">
          <h3>Shop Flowers</h3>
          <p>Browse our collection</p>
        </a>
        <a href="/customization" class="dashboard-card">
          <h3>Customize</h3>
          <p>Create your arrangement</p>
        </a>
        <a href="/cart" class="dashboard-card">
          <h3>Cart</h3>
          <p>View your cart</p>
        </a>
        <a href="/seller" class="dashboard-card">
          <h3>Become a Seller</h3>
          <p>Sell your flowers</p>
        </a>
        <a href="/knowmore" class="dashboard-card">
          <h3>About</h3>
          <p>Learn about AFF</p>
        </a>
      </div>
    </div>
  </section>

  <footer class="footer">
    <div class="container">
      <p>AFF — 3-Tier Microservices Architecture Demo</p>
    </div>
  </footer>
</body>
</html>
