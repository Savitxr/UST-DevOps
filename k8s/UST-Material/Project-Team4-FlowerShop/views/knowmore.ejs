<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AFF | About Us</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    .page-body{padding:2rem;max-width:820px;margin:0 auto;}
    .about-section{margin-bottom:2rem;}
    .info-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1rem;margin-top:1rem;}
    .info-tile{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:1.5rem;text-align:center;}
    .info-tile-art{font-family:var(--mono);white-space:pre;font-size:0.58rem;line-height:1.2;margin-bottom:0.8rem;}
    .info-tile-title{font-family:var(--serif);font-size:0.95rem;letter-spacing:2px;color:var(--text);margin-bottom:0.4rem;}
    .info-tile-text{font-size:0.8rem;color:var(--text-muted);line-height:1.5;}
    .contact-form .form-control{background:rgba(255,255,255,0.03);}
  </style>
</head>
<body>
  <div class="petals-layer">
    <span class="petal" style="color:var(--pink)">*</span>
    <span class="petal" style="color:var(--lavender)">@</span>
    <span class="petal" style="color:var(--mint)">o</span>
    <span class="petal" style="color:var(--pink)">*</span>
    <span class="petal" style="color:var(--gold)">.</span>
    <span class="petal" style="color:var(--lavender)">@</span>
    <span class="petal" style="color:var(--mint)">*</span>
    <span class="petal" style="color:var(--pink)">o</span>
    <span class="petal" style="color:var(--lavender)">*</span>
    <span class="petal" style="color:var(--gold)">@</span>
    <span class="petal" style="color:var(--mint)">.</span>
    <span class="petal" style="color:var(--pink)">*</span>
  </div>

  <div class="page-wrap">
    <nav class="navbar">
      <a href="/dashboard" class="navbar-brand">** AFF</a>
      <div class="navbar-links">
        <a href="/product">Browse</a>
        <a href="/customization">Customize</a>
        <a href="/cart">Cart</a>
        <a href="/seller">Seller</a>
        <a href="/knowmore" style="color:var(--mint);">About</a>
        <a href="/auth/logout">Logout</a>
      </div>
    </nav>

    <div class="page-body">

      <!-- Header -->
      <div style="text-align:center;margin:2.5rem 0 2rem;animation:fadeSlideUp 0.5s ease both;">
<pre class="ascii-art pink" style="font-size:0.65rem;opacity:0.6;">
   * * * * * * * * * * * * * * * * * *
  *  ( @ )  ~  ( * )  ~  ( @ )  ~  *
  *   |         |         |         *
  *---+----~----+----~----+---------*
   * * * * * * * * * * * * * * * * * *
</pre>
        <div class="section-title">Abhi's Flower Fusion</div>
        <p class="section-sub">~ EST. 2024  THE STORY OF AFF ~</p>
      </div>

      <!-- About -->
      <div class="about-section glass-card" style="animation:fadeSlideUp 0.6s 0.1s ease both;">
        <div class="ascii-divider" style="margin-bottom:1.2rem;">~ ~ About Us ~ ~</div>
        <p style="line-height:1.8;font-size:0.92rem;color:var(--text-muted);">
          Abhi's Flower Fusion (AFF) is a passionate flower marketplace connecting
          local growers directly with flower lovers. We believe every bloom has a story,
          and every story deserves the perfect arrangement. From hand-picked roses to
          custom seasonal bouquets, AFF brings the garden to your doorstep.
        </p>
<pre class="ascii-art lavender" style="font-size:0.58rem;opacity:0.45;margin-top:1rem;text-align:center;">
  "Where every petal tells a story"
        ~*~ AFF ~*~
</pre>
      </div>

      <!-- Feature tiles -->
      <div class="info-grid" style="animation:fadeSlideUp 0.6s 0.2s ease both;">
        <div class="info-tile">
<pre class="info-tile-art" style="color:var(--pink);">
  * @ *
 * ( ) *
  * | *
    |
  ---
</pre>
          <div class="info-tile-title">Fresh Flowers</div>
          <div class="info-tile-text">Sourced daily from local growers. Always seasonal, always fresh.</div>
        </div>
        <div class="info-tile">
<pre class="info-tile-art" style="color:var(--lavender);">
  ~( @ )~
  /  |  \
     |
  -----
</pre>
          <div class="info-tile-title">Custom Bouquets</div>
          <div class="info-tile-text">Design your perfect arrangement with personal messages and wrap colors.</div>
        </div>
        <div class="info-tile">
<pre class="info-tile-art" style="color:var(--mint);">
  [Market]
     |
   --*--
     |
  -------
</pre>
          <div class="info-tile-title">Seller Platform</div>
          <div class="info-tile-text">Growers list their flowers, reach more customers, grow their business.</div>
        </div>
        <div class="info-tile">
<pre class="info-tile-art" style="color:var(--gold);">
  * @ * @ *
  |  [=]  |
   \_____/
</pre>
          <div class="info-tile-title">Easy Ordering</div>
          <div class="info-tile-text">Cart, checkout, and order tracking — all in one seamless flow.</div>
        </div>
      </div>

      <!-- Docker microservices badge -->
      <div class="glass-card" style="margin-top:2rem;animation:fadeSlideUp 0.6s 0.3s ease both;background:rgba(6,214,160,0.04);">
        <div class="ascii-divider" style="margin-bottom:1rem;">~ ~ Powered By ~ ~</div>
<pre class="ascii-art mint" style="font-size:0.6rem;opacity:0.65;text-align:center;">
  [nginx]                  [app]                  [mongodb]
  frontend       ------>   backend    ------>      database
  container                container               container
      |                       |                       |
  frontend-net           app-net               db-net
      |                       |                       |
      +-------[ Docker Bridge Networks ]--------+
                   EC2 Instance
</pre>
        <p style="text-align:center;font-family:var(--mono);font-size:0.72rem;color:var(--text-muted);margin-top:0.8rem;">
          Deployed as Docker microservices on AWS EC2
        </p>
      </div>

      <!-- Contact -->
      <div class="about-section glass-card" style="animation:fadeSlideUp 0.6s 0.35s ease both;margin-top:2rem;">
        <div class="ascii-divider" style="margin-bottom:1.2rem;">~ ~ Contact Us ~ ~</div>
        <form class="contact-form" onsubmit="handleContact(event)">
          <div class="form-group">
            <label>Name</label>
            <input type="text" class="form-control" placeholder="Your name" required>
          </div>
          <div class="form-group">
            <label>Email</label>
            <input type="email" class="form-control" placeholder="you@garden.com" required>
          </div>
          <div class="form-group">
            <label>Message</label>
            <textarea class="form-control" rows="3" placeholder="Tell us about your dream bouquet..." style="resize:vertical;" required></textarea>
          </div>
          <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;">** Send Message</button>
        </form>
      </div>

      <div style="text-align:center;padding:2rem 0;animation:fadeSlideUp 0.6s 0.4s ease both;">
<pre class="ascii-art pink" style="font-size:0.52rem;opacity:0.3;">
~*~*~*~ AFF | Abhi's Flower Fusion | Since 2024 | Docker Powered *~*~*~*~
</pre>
      </div>

    </div>
  </div>

  <script>
    function handleContact(e) {
      e.preventDefault();
      var btn = e.target.querySelector('button[type=submit]');
      btn.textContent = '~~ Message Sent!';
      btn.style.background = 'linear-gradient(135deg, var(--mint), #00b4d8)';
      btn.style.color = '#000';
      setTimeout(function(){ e.target.reset(); btn.textContent = '** Send Message'; btn.style = ''; }, 3000);
    }
  </script>
</body>
</html>
