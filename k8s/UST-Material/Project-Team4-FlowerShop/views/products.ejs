<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AFF | Products</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    .page-body{padding:2rem;max-width:1000px;margin:0 auto;}
    .product-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:1.4rem;margin-top:1.5rem;}
    .product-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:1.6rem;transition:all 0.3s ease;position:relative;overflow:hidden;}
    .product-card::after{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--pink),var(--lavender),var(--mint));opacity:0;transition:opacity 0.3s;}
    .product-card:hover{transform:translateY(-4px);border-color:rgba(255,105,180,0.4);box-shadow:0 12px 35px rgba(0,0,0,0.4);}
    .product-card:hover::after{opacity:1;}
    .product-name{font-family:var(--serif);font-size:1.05rem;font-weight:700;color:var(--text);margin-bottom:0.4rem;letter-spacing:1px;}
    .product-desc{font-size:0.82rem;color:var(--text-muted);margin-bottom:1rem;line-height:1.5;}
    .product-art{font-family:var(--mono);white-space:pre;font-size:0.55rem;line-height:1.2;color:var(--pink);opacity:0.55;margin-bottom:0.8rem;}
    .product-footer{display:flex;align-items:center;justify-content:space-between;gap:0.8rem;flex-wrap:wrap;margin-top:1rem;}
    .empty-state{text-align:center;padding:4rem 2rem;color:var(--text-muted);}
  </style>
</head>
<body>
  <div class="petals-layer">
    <span class="petal" style="color:var(--pink)">*</span>
    <span class="petal" style="color:var(--lavender)">@</span>
    <span class="petal" style="color:var(--mint)">o</span>
    <span class="petal" style="color:var(--pink)">*</span>
    <span class="petal" style="color:var(--gold)">.</span>
    <span class="petal" style="color:var(--lavender)">@</span>
    <span class="petal" style="color:var(--mint)">*</span>
    <span class="petal" style="color:var(--pink)">o</span>
    <span class="petal" style="color:var(--lavender)">*</span>
    <span class="petal" style="color:var(--gold)">@</span>
    <span class="petal" style="color:var(--mint)">.</span>
    <span class="petal" style="color:var(--pink)">*</span>
  </div>

  <div class="page-wrap">
    <nav class="navbar">
      <a href="/dashboard" class="navbar-brand">** AFF</a>
      <div class="navbar-links">
        <a href="/product" style="color:var(--pink);">Browse</a>
        <a href="/customization">Customize</a>
        <a href="/cart">Cart</a>
        <a href="/seller">Seller</a>
        <a href="/knowmore">About</a>
        <a href="/auth/logout">Logout</a>
      </div>
    </nav>

    <div class="page-body">

      <div style="text-align:center;margin:2rem 0 1rem;animation:fadeSlideUp 0.5s ease both;">
<pre class="ascii-art mint" style="font-size:0.6rem;opacity:0.5;">
  * @ * @ * @ * @ * @ * @ * @ * @ * @ *
 ( FRESH DAILY ) ( HAND PICKED ) ( SEASONAL )
  * @ * @ * @ * @ * @ * @ * @ * @ * @ *
</pre>
        <div class="section-title">The Garden</div>
        <p class="section-sub">~ BROWSE OUR COLLECTION ~</p>
      </div>

      <% if (success_msg && success_msg.length > 0) { %>
        <div class="alert alert-success"><%= success_msg %></div>
      <% } %>

      <% if (products && products.length > 0) { %>
      <div class="product-grid" style="animation:fadeSlideUp 0.6s 0.15s ease both;">
        <% products.forEach(function(product, i) { %>
          <div class="product-card">
            <% var arts = [
              "  * @ *\n * (@) *\n  * | *\n    |\n  -----",
              "  ~( * )~\n  / | \\\n /  |  \\\n    |\n  -----",
              "   _\n  ( )\n ((@))\n  ) (\n   |\n -----",
              "  o o o\n  \\|/\n -[*]-\n  /|\\\n  ---"
            ]; %>
<pre class="product-art"><%= arts[i % 4] %></pre>
            <div class="product-name"><%= product.name %></div>
            <div class="product-desc"><%= product.description %></div>
            <div class="ascii-divider" style="margin:0.6rem 0;font-size:0.6rem;">- - ~ - -</div>
            <div class="product-footer">
              <span class="price-badge">$<%= product.price %></span>
              <form action="/cart/add" method="POST" style="display:flex;align-items:center;gap:0.5rem;">
                <input type="number" name="quantity" value="1" min="1" class="qty-input">
                <input type="hidden" name="productId" value="<%= product._id %>">
                <button type="submit" class="btn btn-primary" style="padding:0.5rem 1.1rem;font-size:0.82rem;">
                  + Add
                </button>
              </form>
            </div>
          </div>
        <% }); %>
      </div>
      <% } else { %>
      <div class="empty-state glass-card" style="animation:fadeSlideUp 0.6s ease both;">
<pre class="ascii-art lavender" style="font-size:0.7rem;opacity:0.5;text-align:center;">
    ( * )
   / | \
  /  |  \
     |
   -----
</pre>
        <p style="margin-top:1rem;font-family:var(--mono);">~ The garden is being planted ~</p>
        <p style="font-size:0.8rem;color:var(--text-muted);margin-top:0.5rem;">No products listed yet</p>
      </div>
      <% } %>

      <div style="text-align:center;margin-top:2.5rem;animation:fadeSlideUp 0.6s 0.3s ease both;">
        <a href="/cart" class="btn btn-secondary" style="font-size:1rem;padding:0.85rem 2.2rem;">
          ~~ View Cart
        </a>
        <a href="/dashboard" class="btn btn-ghost" style="margin-left:0.8rem;">Back</a>
      </div>

    </div>
  </div>
</body>
</html>
