<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AFF | Seller Registration</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    .page-body{padding:2rem;max-width:680px;margin:0 auto;}
    .two-col{display:grid;grid-template-columns:1fr 1fr;gap:1rem;}
    @media(max-width:540px){.two-col{grid-template-columns:1fr;}}
  </style>
  <script>
    window.addEventListener('DOMContentLoaded', function() {
      var msg = document.getElementById('js-success-msg');
      if (msg && msg.dataset.msg) {
        setTimeout(function(){ window.location.href = '/dashboard'; }, 2000);
      }
    });
  </script>
</head>
<body>
  <div class="petals-layer">
    <span class="petal" style="color:var(--mint)">*</span>
    <span class="petal" style="color:var(--pink)">@</span>
    <span class="petal" style="color:var(--lavender)">o</span>
    <span class="petal" style="color:var(--mint)">*</span>
    <span class="petal" style="color:var(--gold)">.</span>
    <span class="petal" style="color:var(--pink)">@</span>
    <span class="petal" style="color:var(--lavender)">*</span>
    <span class="petal" style="color:var(--mint)">o</span>
    <span class="petal" style="color:var(--pink)">*</span>
    <span class="petal" style="color:var(--gold)">@</span>
    <span class="petal" style="color:var(--lavender)">.</span>
    <span class="petal" style="color:var(--mint)">*</span>
  </div>

  <div class="page-wrap">
    <nav class="navbar">
      <a href="/dashboard" class="navbar-brand">** AFF</a>
      <div class="navbar-links">
        <a href="/product">Browse</a>
        <a href="/customization">Customize</a>
        <a href="/cart">Cart</a>
        <a href="/seller" style="color:var(--mint);">Seller</a>
        <a href="/knowmore">About</a>
        <a href="/auth/logout">Logout</a>
      </div>
    </nav>

    <div class="page-body">

      <div style="text-align:center;margin:2rem 0 1.5rem;animation:fadeSlideUp 0.5s ease both;">
<pre class="ascii-art mint" style="font-size:0.65rem;opacity:0.6;">
  [Market]     [Farm]     [Garden]
     |            |            |
   --*--        --o--        --@--
     |            |            |
  ~~ grow ~~ sell ~~ bloom ~~
</pre>
        <div class="section-title">Become a Seller</div>
        <p class="section-sub">~ JOIN OUR GROWER COMMUNITY ~</p>
      </div>

      <% if (success_msg && success_msg.length > 0) { %>
        <div class="alert alert-success" id="js-success-msg" data-msg="<%= success_msg %>">
          <span style="font-family:var(--mono);">** </span><%= success_msg %> — Redirecting to dashboard...
        </div>
      <% } %>
      <% if (error_msg && error_msg.length > 0) { %>
        <div class="alert alert-danger"><%= error_msg %></div>
      <% } %>

      <div class="glass-card" style="animation:fadeSlideUp 0.6s 0.15s ease both;">
        <div class="ascii-divider" style="margin-bottom:1.5rem;">~ ~ fill in your grower details ~ ~</div>
        <form action="/seller" method="POST">

          <div class="two-col">
            <div class="form-group">
              <label>Full Name</label>
              <input type="text" name="name" class="form-control" placeholder="Your name" required>
            </div>
            <div class="form-group">
              <label>Age</label>
              <input type="number" name="age" class="form-control" placeholder="e.g. 30" required>
            </div>
          </div>

          <div class="two-col">
            <div class="form-group">
              <label>Gender</label>
              <input type="text" name="gender" class="form-control" placeholder="e.g. Male / Female" required>
            </div>
            <div class="form-group">
              <label>Phone Number</label>
              <input type="text" name="phone" class="form-control" placeholder="+91 XXXXX XXXXX" required>
            </div>
          </div>

          <div class="form-group">
            <label>Email Address</label>
            <input type="email" name="email" class="form-control" placeholder="seller@garden.com" required>
          </div>

          <div class="two-col">
            <div class="form-group">
              <label>Residential Address</label>
              <input type="text" name="residentialAddress" class="form-control" placeholder="Home address" required>
            </div>
            <div class="form-group">
              <label>Farm / Shop Address</label>
              <input type="text" name="farmAddress" class="form-control" placeholder="Farm / shop location" required>
            </div>
          </div>

          <div class="two-col">
            <div class="form-group">
              <label>Bank Account No.</label>
              <input type="text" name="bankAccount" class="form-control" placeholder="Account number" required>
            </div>
            <div class="form-group">
              <label>IFSC Code</label>
              <input type="text" name="ifscCode" class="form-control" placeholder="e.g. SBIN0001234" required>
            </div>
          </div>

          <div class="form-group">
            <label>Types of Flowers You Sell</label>
            <input type="text" name="flowerTypes" class="form-control" placeholder="e.g. Roses, Tulips, Orchids" required>
          </div>

          <div class="ascii-divider" style="margin:1.2rem 0;">- - ( * ) - register your garden - ( * ) - -</div>

          <button type="submit" class="btn btn-mint" style="width:100%;justify-content:center;padding:0.9rem;color:#000;">
            ~~ Register as Seller
          </button>
        </form>
      </div>

    </div>
  </div>
</body>
</html>
